# Docker production env - copy to .env and customize
#   cp .env.example .env
#
# Used by docker-compose.prod.yml for Keycloak

# Neon PostgreSQL (Keycloak database)
KC_DB_URL=jdbc:postgresql://your-neon-host.neon.tech/keycloak?sslmode=require
KC_DB_USERNAME=neondb_owner
KC_DB_PASSWORD=your-password

# Keycloak public hostname (from Cloudflare Tunnel)
# e.g. auth.billpromax.in - used for token issuer, redirects
KC_HOSTNAME=auth.yourdomain.com

# Keycloak admin (optional, defaults to admin/admin)
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
