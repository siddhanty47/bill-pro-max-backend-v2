{
  "id": "billpromax",
  "realm": "billpromax",
  "displayName": "BillProMax",
  "displayNameHtml": "<strong>BillProMax</strong>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 3600,
  "accessTokenLifespanForImplicitFlow": 3600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 86400,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespanEnabled": false,
  "clientSessionIdleTimeout": 0,
  "clientSessionMaxLifespan": 0,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "roles": {
    "realm": [
      {
        "name": "owner",
        "description": "Business owner with full access",
        "composite": true,
        "composites": {
          "realm": ["manager", "staff", "accountant", "viewer"]
        }
      },
      {
        "name": "manager",
        "description": "Manager with operational access",
        "composite": true,
        "composites": {
          "realm": ["staff", "viewer"]
        }
      },
      {
        "name": "staff",
        "description": "Staff with basic operational access",
        "composite": false
      },
      {
        "name": "accountant",
        "description": "Accountant with financial access",
        "composite": true,
        "composites": {
          "realm": ["viewer"]
        }
      },
      {
        "name": "viewer",
        "description": "Read-only access",
        "composite": false
      },
      {
        "name": "client-portal",
        "description": "Client portal access for external clients",
        "composite": false
      }
    ],
    "client": {
      "billpromax-api": [],
      "billpromax-web": []
    }
  },
  "groups": [
    {
      "name": "business-users",
      "path": "/business-users",
      "subGroups": []
    },
    {
      "name": "clients",
      "path": "/clients",
      "subGroups": []
    }
  ],
  "users": [
    {
      "username": "admin@billpromax.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@billpromax.com",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "requiredActions": [],
      "realmRoles": ["owner"],
      "groups": ["/business-users"],
      "attributes": {
        "businessIds": []
      }
    },
    {
      "username": "demo@billpromax.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo@billpromax.com",
      "credentials": [
        {
          "type": "password",
          "value": "demo123",
          "temporary": false
        }
      ],
      "requiredActions": [],
      "realmRoles": ["manager"],
      "groups": ["/business-users"],
      "attributes": {
        "businessIds": []
      }
    }
  ],
  "clients": [
    {
      "clientId": "billpromax-web",
      "name": "BillProMax Web Application",
      "description": "Frontend web application for BillProMax",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:5173/*",
        "http://localhost:5174/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost:5173",
        "http://localhost:5174"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:5173/*##http://localhost:5174/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access"
      ]
    },
    {
      "clientId": "billpromax-backend",
      "name": "BillProMax Backend Client",
      "description": "Backend API client for token validation and direct access grants",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "billpromax-backend-secret",
      "bearerOnly": false,
      "attributes": {},
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "business-access"
      ]
    },
    {
      "clientId": "billpromax-admin",
      "name": "BillProMax Admin Client",
      "description": "Admin client for managing users via Keycloak Admin API",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "protocol": "openid-connect",
      "secret": "billpromax-admin-secret",
      "bearerOnly": false,
      "attributes": {},
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "billpromax-api",
      "name": "BillProMax API Backend (Legacy)",
      "description": "Legacy backend API client - use billpromax-backend instead",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "billpromax-api-secret",
      "bearerOnly": false,
      "attributes": {},
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "business-access"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "description": "OpenID Connect scope for user roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "client_roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "business-access",
      "description": "Scope for business ID access",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "businessIds",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "businessIds",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "businessIds",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "openid",
    "profile",
    "email",
    "roles",
    "business-access"
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "smtpServer": {},
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": [
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "REGISTER",
    "REGISTER_ERROR",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR",
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR",
    "REFRESH_TOKEN",
    "REFRESH_TOKEN_ERROR",
    "UPDATE_PASSWORD",
    "UPDATE_PASSWORD_ERROR"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true
}
