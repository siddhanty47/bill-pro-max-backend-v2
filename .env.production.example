# Production environment for backend
# Copy to .env.production and fill in your values
#   cp .env.production.example .env.production

NODE_ENV=production
PORT=3001
API_VERSION=v1

# CORS - Your frontend domain (required in production)
CORS_ORIGIN=https://app.billpromax.com

RATE_LIMIT_MAX=500

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/billpromax?retryWrites=true&w=majority
MONGODB_DATABASE=billpromax

# Redis - Overridden by docker-compose to redis://redis:6379
REDIS_URL=redis://localhost:6379

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# File Storage
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=/app/uploads

# Email, Frontend URL, etc.
RESEND_API_KEY=
EMAIL_FROM=billing@yourdomain.com
FRONTEND_URL=https://app.billpromax.com

LOG_LEVEL=info

#Anthropic api key for extracting text from image. (eg: challan)
ANTHROPIC_API_KEY=anthropic-api-key