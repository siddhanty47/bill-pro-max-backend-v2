# Production environment for backend (server / Cloudflare Tunnel setup)
# Copy to .env.production and fill in your values
#   cp .env.production.example .env.production
#
# Used by docker-compose.prod.yml. MongoDB (Atlas) and Keycloak (public URL) are external.

NODE_ENV=production
PORT=3001
API_VERSION=v1

# CORS - Your frontend domain (required in production)
CORS_ORIGIN=https://app.billpromax.com

RATE_LIMIT_MAX=500

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/billpromax?retryWrites=true&w=majority
MONGODB_DATABASE=billpromax

# Redis - Overridden by docker-compose to redis://redis:6379
REDIS_URL=redis://localhost:6379

# Keycloak - Overridden by docker-compose to http://keycloak:8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=billpromax
KEYCLOAK_CLIENT_ID=billpromax-backend
KEYCLOAK_CLIENT_SECRET=billpromax-backend-secret

# Keycloak Admin (for invitations)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# JWT - MUST match your public Keycloak URL (from Cloudflare Tunnel)
# e.g. https://auth.billpromax.com/realms/billpromax
JWT_ISSUER=https://auth.yourdomain.com/realms/billpromax

# File Storage
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=/app/uploads

# Email, Frontend URL, etc.
RESEND_API_KEY=
EMAIL_FROM=billing@yourdomain.com
FRONTEND_URL=https://app.billpromax.com

LOG_LEVEL=info
