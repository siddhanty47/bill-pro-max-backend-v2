# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1

# CORS - Allowed frontend origin (use exact URL in production, '*' for dev)
CORS_ORIGIN=*

# Rate Limiting - Max requests per 15-minute window per IP
RATE_LIMIT_MAX=500

# MongoDB Configuration
MONGODB_URI=mongodb://billpromax:password@localhost:27017/billpromax?authSource=admin
MONGODB_DATABASE=billpromax

# Redis Configuration (for Bull queues and bulk bill generation)
# Development: use local Redis from docker-compose
#   docker-compose up -d  # starts Redis on localhost:6379
# Production: use managed Redis (Upstash, Redis Cloud, AWS ElastiCache, etc.)
#   - Upstash: rediss://default:PASSWORD@HOST:6379 (TLS)
#   - Self-hosted: redis://HOST:6379 or redis://USER:PASSWORD@HOST:6379
REDIS_URL=redis://localhost:6379

# Supabase Auth Configuration
# Get these from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# File Storage
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=./uploads
# AWS S3 (if using S3)
AWS_S3_BUCKET=billpromax-files
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=billing@yourdomain.com

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# GSTIN Lookup API (gstincheck.co.in)
# Get your free API key at https://gstincheck.co.in/
GSTIN_API_KEY=d4bd183c87a6716c041aacef4222428c

# Frontend URL (used for invitation email links)
FRONTEND_URL=http://localhost:5174

# Logging
LOG_LEVEL=info

#Anthropic api key for extracting text from image. (eg: challan)
ANTHROPIC_API_KEY=anthropic-api-key